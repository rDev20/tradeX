# ==========================================
# tradeX — Environment Variables (Local Dev)
# Copy to `.env` and fill in your values.
# Never commit `.env`. Never paste real secrets here.
# ==========================================

# Runtime
NODE_ENV=development
LOG_LEVEL=debug

# ------------------------------------------
# Frontend (Next.js)
# ------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_SENTRY_DSN=

# ------------------------------------------
# API (NestJS)
# ------------------------------------------
API_PORT=4000
WS_PORT=4001

# Auth (Clerk)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Database
DATABASE_URL=postgresql://tradex:tradex@localhost:5432/tradex_dev
DATABASE_URL_ANALYTICS=clickhouse://localhost:9000/tradex_analytics

# Redis
REDIS_URL=redis://localhost:6379

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=tradex-dev
TEMPORAL_API_KEY=

# KMS (dev uses local-kms, prod uses AWS KMS)
KMS_PROVIDER=local
KMS_KEY_ID=local-dev-key

# ------------------------------------------
# External Services
# ------------------------------------------

# OpenAI — for signal parsing
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Telegram — per-user session, not a global bot
# These are Telegram's API access creds for our Telethon client,
# NOT a user's Telegram session.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Razorpay
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# MSG91 (SMS / OTP)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Resend (email)
RESEND_API_KEY=

# Zerodha Kite — OAuth app credentials (not a user's token)
KITE_APP_API_KEY=
KITE_APP_API_SECRET=
KITE_REDIRECT_URL=http://localhost:4000/broker/kite/oauth/callback

# ------------------------------------------
# Observability
# ------------------------------------------
DATADOG_API_KEY=
DATADOG_SITE=us5.datadoghq.com
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
POSTHOG_PERSONAL_API_KEY=

# ------------------------------------------
# Feature Flags (overrides only — canonical store is PostHog)
# ------------------------------------------
FEATURE_LIVE_TRADING=false
FEATURE_MULTI_BROKER=false
FEATURE_LEADERBOARD=false

# ------------------------------------------
# Local dev overrides
# ------------------------------------------
DEV_MOCK_KITE=true
DEV_MOCK_TELEGRAM=true
DEV_MOCK_OPENAI=false
DEV_SEED_USERS=5
